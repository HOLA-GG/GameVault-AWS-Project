# App
APP_ENV=development
SECRET_KEY=change-me
DATABASE_URL=sqlite+pysqlite:///gamevault_dev.db
STORAGE_BACKEND=none
PREFERRED_URL_SCHEME=http
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax
WTF_CSRF_ENABLED=true
WTF_CSRF_TIME_LIMIT=3600
WTF_CSRF_SSL_STRICT=false
LOG_LEVEL=INFO
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0

# Rate limiting and uploads
RATELIMIT_STORAGE_URI=memory://
MAX_UPLOAD_MB=5
GAMES_PER_PAGE=12
ADMIN_USERS_PER_PAGE=25
ADMIN_LOGS_PER_PAGE=50
RESET_TOKEN_EXPIRY_MINUTES=30
AUDIT_LOG_RETENTION_DAYS=90

# Legacy AWS / future object storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=gamevault-media-files
S3_ALLOWED_ORIGINS=http://127.0.0.1:5000,http://localhost:5000
DYNAMODB_TABLE=GameVault
DYNAMODB_USERS_TABLE=GameVaultUsers
DYNAMODB_RESET_TABLE=GameVaultPasswordReset
DYNAMODB_AUDIT_TABLE=GameVaultAuditLogs
DYNAMODB_RESET_TOKEN_INDEX=reset-token-index
DYNAMODB_AUDIT_TIMESTAMP_INDEX=scope-timestamp-index

# Mail / SES SMTP
MAIL_SERVER=email-smtp.us-east-1.amazonaws.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=GameVault <noreply@gamevault.app>
MAIL_SUPPRESS_SEND=false

# Optional bootstrap admin
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=GameVault
BOOTSTRAP_ADMIN_LAST_NAME=Admin
